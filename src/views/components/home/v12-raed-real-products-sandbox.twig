{# V12I Raed Real Products Sandbox
   This is a safe, isolated section to test real store products using the official Raed product-card mechanism.
   It relies purely on the globally loaded `custom-salla-product-card` from `product-card.js`.
#}

<section class="section-padding-sm container" id="alj-real-products-sandbox">
  <div class="section-header">
    <h2 class="section-title">اختبار المنتجات الحقيقية<span class="title-accent"></span></h2>
    <p class="section-subtitle">تجربة ربط منتجات المتجر عبر طريقة Raed الرسمية</p>
  </div>
  
  <style>
    /* 1. Force the inner wrapper to behave as a grid, NOT the outer component */
    #alj-real-products-sandbox salla-products-list {
      display: block !important;
      width: 100% !important;
    }
    
    #alj-real-products-sandbox .s-products-list-wrapper,
    #alj-real-products-sandbox .s-products-list-vertical-cards,
    #alj-real-products-sandbox .s-products-list-row-cards {
      display: grid !important;
      grid-template-columns: repeat(4, 1fr) !important;
      gap: 25px !important;
      width: 100% !important;
    }

    @media (max-width: 1024px) {
      #alj-real-products-sandbox .s-products-list-wrapper,
      #alj-real-products-sandbox .s-products-list-vertical-cards,
      #alj-real-products-sandbox .s-products-list-row-cards { 
        grid-template-columns: repeat(3, 1fr) !important; 
      }
    }
    @media (max-width: 768px) {
      #alj-real-products-sandbox .s-products-list-wrapper,
      #alj-real-products-sandbox .s-products-list-vertical-cards,
      #alj-real-products-sandbox .s-products-list-row-cards { 
        grid-template-columns: repeat(2, 1fr) !important; 
        gap: 12px !important; 
      }
    }

    /* Hide the "Load More" or "تعذر جلب المزيد" block in the sandbox */
    #alj-real-products-sandbox salla-products-list > *:not(.s-products-list-wrapper):not(.s-products-list-vertical-cards):not(.s-products-list-row-cards):not(.products-list),
    #alj-real-products-sandbox .s-products-list-loading-wrapper,
    #alj-real-products-sandbox .s-products-list-placeholder,
    #alj-real-products-sandbox .s-infinite-scroll-wrapper,
    #alj-real-products-sandbox [class*="placeholder"]:not(img),
    #alj-real-products-sandbox [class*="load-more"],
    #alj-real-products-sandbox [class*="loading"] {
      display: none !important;
      opacity: 0 !important;
      visibility: hidden !important;
      height: 0 !important;
      overflow: hidden !important;
      margin: 0 !important;
      padding: 0 !important;
    }

    /* Hide broken image artifacts (e.g. empty or undefined src attributes) */
    #alj-real-products-sandbox img[src=""],
    #alj-real-products-sandbox img:not([src]),
    #alj-real-products-sandbox img[src="undefined"],
    #alj-real-products-sandbox img[src*="undefined"] {
      display: none !important;
    }

    /* 2. Override the native custom-salla-product-card wrapper to match Al Janoub style */
    #alj-real-products-sandbox custom-salla-product-card,
    #alj-real-products-sandbox salla-product-card {
      background: var(--white, #fff) !important;
      border-radius: var(--radius-md, 14px) !important;
      box-shadow: var(--shadow-sm, 0px 4px 15px rgba(0,0,0,0.06)) !important;
      border: 1px solid var(--border-color, #e5e7eb) !important;
      overflow: hidden !important;
      display: flex !important;
      flex-direction: column !important;
      transition: transform 0.3s ease, box-shadow 0.3s ease !important;
      height: 100% !important;
    }
    #alj-real-products-sandbox custom-salla-product-card:hover,
    #alj-real-products-sandbox salla-product-card:hover {
      box-shadow: var(--shadow-md, 5px 10px 30px rgba(0,0,0,0.1)) !important;
      transform: translateY(-5px) !important;
    }

    /* 3. Image container sizing */
    #alj-real-products-sandbox custom-salla-product-card .s-product-card-image,
    #alj-real-products-sandbox salla-product-card .s-product-card-image {
      height: 220px !important;
      background: var(--bg-alt, #f9fafb) !important;
      border-bottom: 1px solid var(--border-color, #e5e7eb) !important;
      padding: 10px !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
    }
    #alj-real-products-sandbox custom-salla-product-card .s-product-card-image img,
    #alj-real-products-sandbox salla-product-card .s-product-card-image img {
      width: 100% !important;
      height: 100% !important;
      object-fit: contain !important;
    }

    /* 4. Text content styling */
    #alj-real-products-sandbox custom-salla-product-card .s-product-card-content,
    #alj-real-products-sandbox salla-product-card .s-product-card-content {
      padding: 15px !important;
      display: flex !important;
      flex-direction: column !important;
      flex-grow: 1 !important;
      text-align: right !important;
    }
    #alj-real-products-sandbox custom-salla-product-card .s-product-card-content-title a,
    #alj-real-products-sandbox salla-product-card .s-product-card-content-title a {
      color: var(--secondary-color, #1f2937) !important;
      font-weight: 700 !important;
      font-size: 1.1rem !important;
      text-decoration: none !important;
    }
    #alj-real-products-sandbox custom-salla-product-card .s-product-card-price,
    #alj-real-products-sandbox salla-product-card .s-product-card-price {
      color: var(--text-dark, #111) !important;
      font-weight: bold !important;
      font-size: 1.1rem !important;
      margin-top: auto !important;
      padding-top: 10px !important;
    }

    /* 5. Wishlist button safe positioning */
    #alj-real-products-sandbox custom-salla-product-card .s-product-card-wishlist-btn,
    #alj-real-products-sandbox salla-product-card .s-product-card-wishlist-btn {
      position: absolute !important;
      top: 10px !important;
      right: 10px !important;
      z-index: 10 !important;
    }

    /* 6. Pill button morphing */
    #alj-real-products-sandbox custom-salla-product-card salla-add-product-button::part(button),
    #alj-real-products-sandbox custom-salla-product-card salla-add-product-button .btn,
    #alj-real-products-sandbox custom-salla-product-card salla-add-product-button button,
    #alj-real-products-sandbox salla-product-card salla-add-product-button::part(button),
    #alj-real-products-sandbox salla-product-card salla-add-product-button .btn,
    #alj-real-products-sandbox salla-product-card salla-add-product-button button {
      background: var(--bg-alt, #f9fafb) !important;
      color: var(--secondary-color, #1f2937) !important;
      border: 1px solid var(--border-color, #e5e7eb) !important;
      border-radius: 20px !important;
      padding: 6px 15px !important;
      font-weight: 700 !important;
      height: auto !important;
      min-height: 0 !important;
      box-shadow: none !important;
      min-width: 80px;
      transition: all 0.3s ease !important;
      margin-top: 10px !important;
    }
    #alj-real-products-sandbox custom-salla-product-card:hover salla-add-product-button::part(button),
    #alj-real-products-sandbox custom-salla-product-card:hover salla-add-product-button .btn,
    #alj-real-products-sandbox custom-salla-product-card:hover salla-add-product-button button,
    #alj-real-products-sandbox salla-product-card:hover salla-add-product-button::part(button),
    #alj-real-products-sandbox salla-product-card:hover salla-add-product-button .btn,
    #alj-real-products-sandbox salla-product-card:hover salla-add-product-button button {
      background: var(--secondary-color, #1f2937) !important;
      color: var(--white, #fff) !important;
    }
  </style>

  <div class="product-grid" style="min-height: 400px; display: block; position: relative; z-index: 5;">
    <salla-products-list source="latest" limit="4" fallback-message="لا توجد منتجات متاحة حالياً" class="w-full">
    </salla-products-list>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const sandbox = document.getElementById('alj-real-products-sandbox');
      if (!sandbox) return;

      const cleanBrokenArtifacts = function() {
        const cards = sandbox.querySelectorAll('custom-salla-product-card, salla-product-card, .s-product-card-entry');
        cards.forEach(card => {
          // 1. Hide Salla's internal icon fonts that represent missing/broken images
          const icons = card.querySelectorAll('i[class*="sicon-image"], i[class*="broken"]');
          icons.forEach(i => { i.style.display = 'none'; i.style.opacity = '0'; });

          // 2. Validate all <img> tags inside the card
          const imgs = card.querySelectorAll('img');
          let foundValidMainImage = false;

          imgs.forEach(img => {
            const src = img.getAttribute('src') || img.currentSrc || '';
            
            // If src is clearly invalid literal
            if (!src || src === 'undefined' || src === 'null' || src.endsWith('null') || src.trim() === '') {
              img.style.display = 'none';
              img.style.opacity = '0';
              return;
            }

            // Attach a native error listener to catch 404s dynamically
            img.addEventListener('error', function() {
              this.style.display = 'none';
              this.style.opacity = '0';
            });

            // If we already found the main product image, treat subsequent images as secondary/hover.
            // If the secondary image is breaking the layout, we hide it as a precaution.
            if (foundValidMainImage) {
               // We only want the primary image in the sandbox for a clean look
               img.style.display = 'none';
               img.style.opacity = '0';
            } else {
               foundValidMainImage = true;
            }
          });
        });
      };

      // Run immediately in case they are already rendered
      setTimeout(cleanBrokenArtifacts, 500);
      setTimeout(cleanBrokenArtifacts, 2000);

      // Run continuously as Twilight hydrates the web components
      const observer = new MutationObserver((mutations) => {
        cleanBrokenArtifacts();
      });
      observer.observe(sandbox, { childList: true, subtree: true });
    });
  </script>
</section>
