{# V12F Code-Managed Best Sellers Grid Component
   Architecture: Safe manual Twig include (no native Salla component engine).
   This component is NOT registered in twilight.json or theme.json.
   It renders the "الأكثر مبيعاً" product grid with 4 static product cards. #}

<!-- Best Sellers -->
<section class="section-padding-sm container">
  <div class="section-header">
    <h2 class="section-title">الأكثر مبيعاً<span class="title-accent"></span></h2>
    <p class="section-subtitle">المنتجات المفضلة لدى عملائنا لجودتها الاستثنائية</p>
  </div>
  
  <style>
    /* Force salla-products-list to behave as our product-grid */
    #v12-best-sellers salla-products-list {
      display: grid !important;
      grid-template-columns: repeat(4, 1fr) !important;
      gap: 25px !important;
      width: 100% !important;
      align-items: stretch;
    }
    @media (max-width: 1024px) {
      #v12-best-sellers salla-products-list { grid-template-columns: repeat(3, 1fr) !important; }
    }
    @media (max-width: 768px) {
      #v12-best-sellers salla-products-list { grid-template-columns: repeat(2, 1fr) !important; gap: 12px !important; }
    }

    /* Target the inner button of Salla's add-to-cart web component */
    v12-best-seller-card salla-add-product-button::part(button),
    v12-best-seller-card salla-add-product-button .btn,
    v12-best-seller-card salla-add-product-button button,
    .alj-pill-btn {
      background: var(--bg-alt) !important;
      color: var(--secondary-color) !important;
      border: 1px solid var(--border-color) !important;
      border-radius: 20px !important;
      padding: 6px 15px !important;
      font-weight: 700 !important;
      height: auto !important;
      min-height: 0 !important;
      box-shadow: none !important;
      min-width: 80px;
      transition: var(--transition);
    }
    v12-best-seller-card:hover salla-add-product-button::part(button),
    v12-best-seller-card:hover salla-add-product-button .btn,
    v12-best-seller-card:hover salla-add-product-button button {
      background: var(--secondary-color) !important;
      color: var(--white) !important;
    }
  </style>

  <div id="v12-best-sellers" class="product-grid" style="min-height: 400px; display: block;">
    <salla-products-list source="latest" limit="4" product-card-component="v12-best-seller-card" fallback-message="لا توجد منتجات متاحة حالياً" class="w-full">
    </salla-products-list>
  </div>
</section>
