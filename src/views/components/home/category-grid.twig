<section class="py-16 bg-coffee-dark">
    <div class="container mx-auto px-4">
        <h2 class="text-3xl md:text-4xl font-bold text-center text-gold mb-12">اختر مزاجك</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
            {% for category in store.categories|slice(0, 4) %}
                <a href="{{ category.url }}" class="group relative block h-80 rounded-lg overflow-hidden border border-gold/30 hover:border-gold transition-colors duration-300">
                    <img src="{{ category.image.url|default('https://via.placeholder.com/400x400.png?text=Coffee') }}" alt="{{ category.name }}" class="absolute inset-0 w-full h-full object-cover opacity-60 group-hover:opacity-80 group-hover:scale-110 transition-all duration-500">
                    <div class="absolute inset-0 bg-gradient-to-t from-coffee-dark/90 to-transparent"></div>
                    <div class="absolute bottom-0 left-0 w-full p-6 text-center">
                        <h3 class="text-xl font-bold text-cream group-hover:text-gold transition-colors">{{ category.name }}</h3>
                    </div>
                </a>
            {% endfor %}
        </div>
    </div>
</section>
