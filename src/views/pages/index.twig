    window.__ALJ_RUNTIME_ISOLATION_RUNS__ = 0;

    function isolateHomepage() {
      try {
        var rootWrapper = document.querySelector('.alj-static-homepage');
        if (!rootWrapper) return;

        var hiddenCount = 0;
        var allElements = document.body.querySelectorAll('*');
        for (var i = 0; i < allElements.length; i++) {
          var el = allElements[i];
          if (SAFE_TAGS[el.tagName] || el === rootWrapper || rootWrapper.contains(el) || el.contains(rootWrapper)) continue;
          if (el.getAttribute('data-alj-runtime-hidden') === 'true') { hiddenCount++; continue; }
          el.style.setProperty('display', 'none', 'important');
          el.style.setProperty('visibility', 'hidden', 'important');
          el.style.setProperty('opacity', '0', 'important');
          el.style.setProperty('pointer-events', 'none', 'important');
          el.style.setProperty('height', '0', 'important');
          el.style.setProperty('max-height', '0', 'important');
          el.style.setProperty('overflow', 'hidden', 'important');
          el.style.setProperty('margin', '0', 'important');
          el.style.setProperty('padding', '0', 'important');
          el.style.setProperty('position', 'absolute', 'important');
          el.style.setProperty('width', '0', 'important');
          el.setAttribute('data-alj-runtime-hidden', 'true');
          hiddenCount++;
        }

        document.body.classList.add('alj-runtime-isolated');
        window.__ALJ_RUNTIME_HIDDEN_COUNT__ = hiddenCount;
        window.__ALJ_RUNTIME_ISOLATION_RUNS__++;
      } catch (e) { /* Fail silently */ }
    }

    /* Debounced scheduler to prevent infinite loops */
    var aljIsolationTimer = null;
    function scheduleIsolation() {
      clearTimeout(aljIsolationTimer);
      aljIsolationTimer = setTimeout(isolateHomepage, 50);
    }

    /* Multiple scheduled runs */
    document.addEventListener('DOMContentLoaded', isolateHomepage);
    window.addEventListener('load', isolateHomepage);
    setTimeout(isolateHomepage, 100);
    setTimeout(isolateHomepage, 500);
    setTimeout(isolateHomepage, 1500);
    setTimeout(isolateHomepage, 3000);

    /* Event-driven re-isolation */
    document.addEventListener('click', scheduleIsolation, true);
    document.addEventListener('focusin', scheduleIsolation, true);
    document.addEventListener('submit', scheduleIsolation, true);
    document.addEventListener('input', scheduleIsolation, true);

    /* MutationObserver for dynamically injected nodes */
    if (typeof MutationObserver !== 'undefined') {
      var observer = new MutationObserver(function(mutations) {
        var needsRun = false;
        for (var m = 0; m < mutations.length; m++) {
          if (mutations[m].addedNodes && mutations[m].addedNodes.length > 0) { needsRun = true; break; }
        }
        if (needsRun) scheduleIsolation();
      });
      var startObserver = function() {
        if (document.body) {
          observer.observe(document.body, { childList: true, subtree: true });
        } else {
          document.addEventListener('DOMContentLoaded', function() {
            observer.observe(document.body, { childList: true, subtree: true });
          });
        }
      };
      startObserver();
    }
  })();
</script>
