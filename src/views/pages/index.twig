{% extends "layouts.master" %}

{% block content %}
<!-- V11E premium visual polish: Mobile UX layout improvements, refined spacing, and subtle visual balancing before dynamic component conversion. -->

<style>
  :root {
    --primary-color: #3b2818; /* Rich Coffee Brown */
    --secondary-color: #1e3b2b; /* Deep Green */
    --accent-color: #cda434; /* Premium Gold */
    --accent-light: #fdfaf3; /* Very Light Gold/Cream */
    --accent-glow: rgba(205, 164, 52, 0.15);
    --bg-main: #fcfbfa; /* Slightly warmer white/cream */
    --bg-alt: #f4f1eb; /* Soft contrast background */
    --white: #ffffff;
    --text-dark: #1a1a1a;
    --text-light: #666666;
    --text-muted: #888888;
    --border-color: #f0ebe4;
    --shadow-sm: 0 4px 15px rgba(0, 0, 0, 0.03);
    --shadow-md: 0 8px 25px rgba(0, 0, 0, 0.05);
    --shadow-hover: 0 15px 40px rgba(30, 59, 43, 0.08);
    --radius-sm: 8px;
    --radius-md: 14px;
    --radius-lg: 20px;
    --transition: all 0.3s ease;
  }
  
  /* --- Static prototype runtime isolation: hides default Salla layout artifacts outside .alj-static-homepage. Must be replaced with proper dynamic components during V12+. --- */
  body:has(.alj-static-homepage) > header:not(.alj-store-header),
  body:has(.alj-static-homepage) > footer:not(.alj-store-footer),
  body:has(.alj-static-homepage) .store-header,
  body:has(.alj-static-homepage) .store-footer,
  body:has(.alj-static-homepage) .main-menu,
  body:has(.alj-static-homepage) .mobile-menu,
  body:has(.alj-static-homepage) .main-nav-container,
  body:has(.alj-static-homepage) .salla-demo-ribbon,
  body:has(.alj-static-homepage) .demo-badge,
  body:has(.alj-static-homepage) .demo-notice,
  body:has(.alj-static-homepage) #twilight-toolbar,
  body:has(.alj-static-homepage) .twilight-toolbar {
    display: none !important;
  }
  
  .alj-static-homepage ~ * {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    pointer-events: none !important;
    height: 0 !important;
    max-height: 0 !important;
    overflow: hidden !important;
    margin: 0 !important;
    padding: 0 !important;
    position: absolute !important;
    width: 0 !important;
  }

  body.alj-runtime-isolated {
    background: #fcfbfa !important;
  }
  body.alj-runtime-isolated .alj-static-homepage {
    display: block !important;
    width: 100% !important;
    min-height: auto !important;
  }
  body.alj-runtime-isolated [data-alj-runtime-hidden="true"] {
    display: none !important;
    visibility: hidden !important;
    opacity: 0 !important;
    pointer-events: none !important;
    height: 0 !important;
    max-height: 0 !important;
    overflow: hidden !important;
    margin: 0 !important;
    padding: 0 !important;
    position: absolute !important;
    width: 0 !important;
  }
  
  body { padding-top: 0 !important; }

  /* --- Global Settings --- */
  .v7-home-wrapper {
    font-family: 'Tajawal', 'Cairo', sans-serif;
    background-color: var(--bg-main);
    color: var(--text-dark);
    line-height: 1.6;
    overflow-x: hidden;
  }
  .container { max-width: 1320px; margin: 0 auto; padding: 0 20px; width: 100%; }
  .section-padding { padding: 50px 0; }
  .section-padding-sm { padding: 30px 0; }
  
  .section-header { text-align: center; margin-bottom: 35px; }
  .section-title {
    font-size: 2.2rem; color: var(--secondary-color); font-weight: 900;
    margin-bottom: 5px; display: inline-block; position: relative;
  }
  .title-accent {
    display: block; width: 60px; height: 3px; background: var(--accent-color);
    margin: 10px auto 0; border-radius: 4px;
  }
  .section-subtitle { color: var(--text-light); font-size: 1.05rem; margin-top: 10px; }

  /* --- V7 Storefront Header --- */
  .alj-store-header {
    background: var(--white);
    position: sticky; top: 0; z-index: 100;
    box-shadow: 0 2px 20px rgba(0,0,0,0.04);
    border-bottom: 2px solid var(--accent-color);
    display: block !important;
  }
  .top-strip {
    background: var(--secondary-color); color: var(--white);
    font-size: 0.85rem; text-align: center; padding: 8px 0; font-weight: 600;
  }
  .main-header-inner {
    display: flex; justify-content: space-between; align-items: center;
    padding: 15px 0; flex-wrap: wrap; gap: 15px;
  }
  .logo-block { display: flex; align-items: center; gap: 15px; text-decoration: none; }
  .logo-icon {
    width: 45px; height: 45px; background: var(--accent-color); color: var(--white);
    display: flex; align-items: center; justify-content: center; border-radius: 12px;
    font-size: 1.5rem; font-weight: 900; box-shadow: var(--shadow-sm); flex-shrink: 0;
  }
  .logo-text h1 { margin: 0; font-size: 1.5rem; color: var(--secondary-color); font-weight: 900; line-height: 1.1; }
  .logo-text span { display: block; font-size: 0.8rem; color: var(--text-light); font-weight: 600; }
  
  .nav-rail-wrapper { display: contents; }
  .nav-links { display: flex; gap: 15px; list-style: none; margin: 0; padding: 0; flex-wrap: wrap; justify-content: center; width: 100%; }
  .nav-links a {
    text-decoration: none; color: var(--text-dark); font-weight: 700; font-size: 0.95rem;
    padding: 5px 8px; border-radius: var(--radius-sm); transition: var(--transition);
  }
  .nav-links a:hover { background: var(--bg-alt); color: var(--accent-color); }

  .header-actions { display: flex; align-items: center; gap: 15px; }
    .search-bar {
    display: flex; align-items: center; gap: 12px; background: var(--bg-alt);
    border-radius: 32px; padding: 10px 24px; border: 1px solid var(--border-color);
    width: 250px; color: var(--text-light); font-size: 0.95rem; transition: var(--transition);
    box-sizing: border-box;
  }
  .search-bar:hover, .search-bar:focus-within { border-color: var(--accent-color); background: var(--white); box-shadow: var(--shadow-sm); }
  .search-bar .search-icon { 
    color: var(--accent-color); font-size: 1.1rem; flex-shrink: 0; 
    border: none; background: transparent; padding: 0; cursor: pointer; display: flex; align-items: center; justify-content: center;
  }
  .search-bar .search-input { 
    border: none; outline: none; background: transparent; width: 100%; min-width: 0; 
    direction: rtl; text-align: right; font: inherit; color: inherit;
  }

  .action-btn {
    width: 42px; height: 42px; background: var(--white); border: 1px solid var(--border-color);
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    color: var(--text-dark); font-size: 1.1rem; text-decoration: none; transition: var(--transition);
    position: relative; flex-shrink: 0;
  }
  .action-btn:hover { border-color: var(--accent-color); color: var(--accent-color); }
  .cart-count {
    position: absolute; top: -2px; right: -2px; background: var(--secondary-color); color: var(--white);
    font-size: 0.65rem; width: 16px; height: 16px; border-radius: 50%; border: 1.5px solid var(--white); display: flex; align-items: center; justify-content: center; font-weight: bold; line-height: 1;
    display: flex; align-items: center; justify-content: center; font-weight: bold;
  }

  /* --- V7 Premium Hero --- */
  .hero-wrapper {
    background: linear-gradient(180deg, var(--white) 0%, var(--bg-main) 100%);
    padding: 40px 20px 50px; position: relative; overflow: hidden;
  }
  .hero-inner {
    display: grid; grid-template-columns: 1.1fr 1fr; gap: 40px; align-items: center;
    max-width: 1320px; margin: 0 auto; position: relative; z-index: 2;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 8px; background: var(--accent-light);
    color: var(--accent-color); padding: 8px 16px; border-radius: 30px; font-weight: 800;
    font-size: 0.85rem; margin-bottom: 20px; border: 1px solid rgba(205,164,52,0.3);
  }
  .hero-title { font-size: 3.8rem; color: var(--secondary-color); font-weight: 900; line-height: 1.1; margin-bottom: 20px; }
  .hero-title span { color: var(--accent-color); display: block; font-size: 2.8rem; }
  .hero-desc { font-size: 1.15rem; color: var(--text-light); margin-bottom: 30px; line-height: 1.8; max-width: 90%; }
  
  .hero-actions { display: flex; gap: 15px; flex-wrap: wrap; }
  .btn { display: inline-flex; align-items: center; justify-content: center; padding: 14px 32px; border-radius: 50px; font-weight: 800; font-size: 1.05rem; text-decoration: none; transition: var(--transition); cursor: pointer; border: none; text-align: center; }
  .btn-primary { background: var(--secondary-color); color: var(--white); box-shadow: var(--shadow-md); }
  .btn-primary:hover { background: var(--primary-color); transform: translateY(-2px); box-shadow: var(--shadow-hover); }
  .btn-outline { background: transparent; color: var(--secondary-color); border: 2px solid var(--border-color); }
  .btn-outline:hover { border-color: var(--accent-color); color: var(--accent-color); }

  .hero-visual-area { position: relative; height: 500px; display: flex; align-items: center; justify-content: center; }
  .visual-bg-glow { position: absolute; width: 450px; height: 450px; background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%); border-radius: 50%; z-index: 1; }
  .visual-card-main {
    position: absolute; z-index: 3; background: var(--white); border-radius: var(--radius-lg); padding: 25px;
    box-shadow: var(--shadow-hover); border: 1px solid var(--white); text-align: center;
    width: 280px; display: flex; flex-direction: column; align-items: center; gap: 15px;
  }
  .art-item-hero-coffee { width: 140px; height: 140px; background: radial-gradient(circle at top left, #5c3a21, #2c1b10); border-radius: 50%; border: 6px solid var(--bg-main); box-shadow: 0 10px 20px rgba(0,0,0,0.1); position: relative; }
  .art-item-hero-coffee::after { content: ''; position: absolute; right: -20px; top: 35px; width: 35px; height: 60px; border: 6px solid var(--bg-main); border-radius: 20px; z-index: -1; }
  .vc-title { font-weight: 900; color: var(--secondary-color); font-size: 1.2rem; }
  .vc-sub { color: var(--accent-color); font-size: 0.9rem; font-weight: 700; }
  
  .visual-card-float1 { position: absolute; top: 15%; right: 0; z-index: 2; background: var(--white); padding: 15px; border-radius: var(--radius-md); box-shadow: var(--shadow-md); animation: float 6s ease-in-out infinite; width: 180px; text-align: center; }
  .art-item-dates { width: 80px; height: 60px; background: #8b5a2b; border-radius: 40px 40px 10px 10px; margin: 0 auto 10px; position: relative; }
  .art-item-dates::before { content: '🌰'; font-size: 2rem; position: absolute; top: -15px; left: 20px; }
  
  .visual-card-float2 { position: absolute; bottom: 15%; left: 0; z-index: 4; background: var(--white); padding: 15px; border-radius: var(--radius-md); box-shadow: var(--shadow-md); animation: float 5s ease-in-out infinite 1s; display: flex; align-items: center; gap: 15px; }
  .art-item-saffron { width: 50px; height: 50px; background: var(--accent-light); border: 2px solid var(--accent-color); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }

  /* --- Benefits Row --- */
  .benefits-row {
    background: var(--white); border-top: 1px solid var(--border-color); border-bottom: 1px solid var(--border-color);
    padding: 20px 0;
  }
  .benefits-inner { display: flex; justify-content: space-around; align-items: center; flex-wrap: wrap; gap: 15px; max-width: 1320px; margin: 0 auto; }
  .benefit-item { display: flex; align-items: center; gap: 10px; color: var(--text-dark); font-weight: 700; font-size: 1rem; }
  .benefit-icon { color: var(--accent-color); font-size: 1.4rem; }

  /* --- Categories --- */
  .cat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .cat-card {
    background: var(--white); border-radius: var(--radius-md); padding: 25px 15px; text-align: center;
    border: 1px solid var(--border-color); box-shadow: var(--shadow-sm); text-decoration: none; transition: var(--transition);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
  }
  .cat-card:hover { border-color: var(--accent-color); transform: translateY(-3px); box-shadow: var(--shadow-md); }
  .cat-icon-area { width: 70px; height: 70px; margin: 0 auto 15px; background: var(--bg-alt); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; transition: var(--transition); }
  .cat-card:hover .cat-icon-area { background: var(--accent-light); color: var(--accent-color); transform: scale(1.05); }
  .cat-name { font-weight: 800; color: var(--secondary-color); font-size: 1.05rem; }

  /* --- Premium Product Cards --- */
  .product-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 25px; }
  .product-card {
    background: var(--white); border-radius: var(--radius-md); overflow: hidden;
    border: 1px solid var(--border-color); box-shadow: var(--shadow-sm);
    transition: var(--transition); display: flex; flex-direction: column; position: relative;
  }
  .product-card:hover { border-color: var(--accent-color); box-shadow: 0 15px 35px var(--accent-glow); transform: translateY(-5px); }
  
  .p-badge { position: absolute; top: 12px; right: 12px; background: var(--accent-color); color: var(--white); padding: 4px 10px; border-radius: 20px; font-size: 0.75rem; font-weight: 800; z-index: 2; box-shadow: 0 4px 10px rgba(0,0,0,0.1); }
  .p-badge.new { background: var(--secondary-color); }
  
  .p-visual { height: 220px; background: var(--bg-alt); position: relative; display: flex; align-items: center; justify-content: center; overflow: hidden; border-bottom: 1px solid var(--border-color); }
  .p-visual::after { content: ''; position: absolute; width: 140px; height: 140px; background: var(--white); border-radius: 50%; opacity: 0.5; filter: blur(15px); }
  .art-box { width: 110px; height: 130px; border-radius: 8px; box-shadow: 0 10px 20px rgba(0,0,0,0.1), inset 0 2px 5px rgba(255,255,255,0.2); position: relative; z-index: 1; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; color: var(--white); border: 1px solid rgba(255,255,255,0.1); }
  .art-coffee-bag { background: linear-gradient(135deg, #2c1b10, #4a2c11); border-radius: 5px 5px 15px 15px; position: relative; }
  .art-coffee-bag::before { content:''; position:absolute; top:-5px; left:20%; width:60%; height:8px; background:#1a0f08; border-radius:3px; }
  .art-dates-box { background: linear-gradient(135deg, #a67c00, #bf953f); height: 70px; width: 130px; border-radius: 4px; border: 1px solid #d4af37; position: relative; }
  .art-dates-box::before { content:''; position:absolute; top:0; left:45%; width:10%; height:100%; background:rgba(255,255,255,0.3); }
  .art-cardamom-jar { background: linear-gradient(to bottom, #d4ebd0, #8cb585); width: 80px; border-radius: 10px 10px 30px 30px; position: relative; }
  .art-cardamom-jar::before { content:''; position:absolute; top:-10px; left:10%; width:80%; height:15px; background:#cda434; border-radius:5px 5px 0 0; }
  .art-saffron-tin { background: linear-gradient(135deg, #e31b23, #a10f16); width: 90px; height: 90px; border-radius: 50%; border: 4px solid #cda434; position: relative; }
  .art-saffron-tin::after { content:''; position:absolute; inset:5px; border-radius:50%; border:1px dashed rgba(255,255,255,0.5); }
  .art-grinder { background: linear-gradient(135deg, #333, #111); width: 80px; height: 150px; border-radius: 10px; position: relative; }
  .art-grinder::before { content:''; position:absolute; top:-15px; left:25%; width:50%; height:20px; background:#cda434; border-radius:10px 10px 0 0; }
  .art-tea { background: linear-gradient(135deg, #2b4522, #1a2e13); border-radius: 5px 5px 20px 20px; position: relative; }
  .art-tea::before { content:''; position:absolute; top:20px; left:15%; width:70%; height:30px; background:#cda434; border-radius:4px; opacity:0.8; }
  .art-hospitality { background: linear-gradient(135deg, #f0f0f0, #d4d4d4); border-radius: 50%; width: 120px; height: 120px; border: 3px solid var(--accent-color); position: relative; }
  .art-hospitality::after { content:''; position:absolute; width:60px; height:60px; background:rgba(255,255,255,0.8); border-radius:50%; }
  .art-camping { background: linear-gradient(135deg, #8b7355, #5c4a3d); border-radius: 15px; height: 100px; width: 140px; position: relative; }
  .art-camping::before { content:''; position:absolute; top:-15px; left:30%; width:40%; height:25px; border:4px solid #4a3627; border-bottom:none; border-radius:10px 10px 0 0; }
  
  .p-info { padding: 20px; display: flex; flex-direction: column; flex-grow: 1; background: var(--white); }
  .p-title { font-size: 1.1rem; color: var(--secondary-color); font-weight: 800; margin-bottom: 5px; line-height: 1.4; }
  .p-desc { font-size: 0.85rem; color: var(--text-light); margin-bottom: 12px; line-height: 1.5; flex-grow: 1; }
  .p-rate { color: var(--accent-color); font-size: 0.8rem; margin-bottom: 15px; letter-spacing: 1px; }
  .p-footer { display: flex; justify-content: space-between; align-items: center; border-top: 1px dashed var(--border-color); padding-top: 15px; margin-top: auto; flex-wrap: wrap; gap: 10px; }
  .p-price { color: var(--secondary-color); font-weight: 900; font-size: 1.3rem; }
  .p-price span { font-size: 0.8rem; color: var(--text-light); }
  .p-add-btn { background: var(--bg-alt); color: var(--secondary-color); border: none; padding: 8px 15px; border-radius: 30px; font-weight: 700; font-size: 0.85rem; cursor: pointer; transition: var(--transition); display: flex; align-items: center; gap: 5px; flex-shrink: 0; border: 1px solid transparent; }
  .product-card:hover .p-add-btn { background: var(--secondary-color); color: var(--white); box-shadow: 0 4px 10px rgba(30, 59, 43, 0.2); }
  .p-add-btn:hover { background: var(--primary-color) !important; color: var(--white) !important; transform: scale(1.05); }

  /* --- Dark Promo Banner --- */
  .promo-banner { background: var(--primary-color); border-radius: var(--radius-lg); padding: 50px 40px; text-align: center; color: var(--white); position: relative; overflow: hidden; box-shadow: var(--shadow-md); margin-top: 20px; }
  .promo-pattern { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-image: radial-gradient(rgba(205,164,52,0.1) 2px, transparent 2px); background-size: 30px 30px; }
  .promo-content { position: relative; z-index: 2; max-width: 600px; margin: 0 auto; }
  .promo-title { font-size: 2.4rem; color: var(--accent-color); font-weight: 900; margin-bottom: 15px; }
  .promo-text { font-size: 1.1rem; opacity: 0.9; margin-bottom: 25px; line-height: 1.6; }

  /* --- Brands --- */
  .brands-grid { display: flex; justify-content: space-between; gap: 15px; flex-wrap: wrap; }
  .brand-card { flex: 1 1 150px; min-width: 130px; background: var(--white); border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 25px 10px; text-align: center; transition: var(--transition); display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .brand-card:hover { border-color: var(--accent-color); box-shadow: var(--shadow-sm); transform: translateY(-2px); }
  .brand-icon { font-size: 2rem; color: var(--primary-color); margin-bottom: 10px; }
  .brand-name { font-weight: 800; font-size: 0.95rem; color: var(--secondary-color); }

  /* --- Footer --- */
  .alj-store-footer { background: #131c16; color: var(--white); padding: 60px 20px 20px; border-top: 4px solid var(--accent-color); margin-top: 40px; display: block !important; }
  .f-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr; gap: 40px; max-width: 1320px; margin: 0 auto; }
  .f-col h4 { font-size: 1.1rem; font-weight: 800; color: var(--white); margin-bottom: 20px; }
  .f-logo { display: flex; align-items: center; gap: 10px; font-size: 1.8rem; font-weight: 900; color: var(--white); text-decoration: none; margin-bottom: 15px; }
  .f-logo span { color: var(--accent-color); }
  .f-logo-icon { width: 35px; height: 35px; background: var(--accent-color); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--white); font-size: 1.2rem; flex-shrink: 0; }
  .f-desc { color: #a0a0a0; font-size: 0.9rem; line-height: 1.8; margin-bottom: 20px; max-width: 90%; }
  .f-socials { display: flex; gap: 10px; flex-wrap: wrap; }
  .f-social { width: 36px; height: 36px; background: rgba(255,255,255,0.05); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--white); text-decoration: none; transition: var(--transition); border: 1px solid rgba(255,255,255,0.1); }
  .f-social:hover { background: var(--accent-color); border-color: var(--accent-color); }
  .f-links { list-style: none; padding: 0; margin: 0; }
  .f-links li { margin-bottom: 10px; }
  .f-links a { color: #a0a0a0; text-decoration: none; font-size: 0.9rem; transition: var(--transition); }
  .f-links a:hover { color: var(--accent-color); padding-right: 5px; }
  .f-contact p { color: #a0a0a0; font-size: 0.9rem; margin-bottom: 10px; display: flex; align-items: center; gap: 8px; }
  .f-bottom { max-width: 1320px; margin: 50px auto 0; padding-top: 20px; border-top: 1px solid rgba(255,255,255,0.1); display: flex; justify-content: space-between; align-items: center; font-size: 0.85rem; color: #888; flex-wrap: wrap; gap: 15px; }
  .f-payments { display: flex; gap: 10px; flex-wrap: wrap; }
  .f-pay-icon { background: var(--white); padding: 4px 8px; border-radius: 4px; font-size: 0.8rem; font-weight: bold; color: var(--primary-color); }

  /* --- Responsive --- */
  @media (max-width: 1100px) {
    .search-bar { width: 200px; }
    .hero-title { font-size: 3rem; } .hero-title span { font-size: 2.2rem; }
    .product-grid { grid-template-columns: repeat(3, 1fr); }
    .cat-grid { grid-template-columns: repeat(4, 1fr); }
    .f-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 850px) {
    .nav-links { display: none; }
    .hero-inner { grid-template-columns: 1fr; text-align: center; gap: 30px; }
    .hero-content { text-align: center; }
    .hero-desc { margin: 0 auto 30px; }
    .hero-actions { justify-content: center; }
    .hero-visual-area { height: 400px; transform: scale(0.9); }
    .cat-grid { grid-template-columns: repeat(2, 1fr); }
