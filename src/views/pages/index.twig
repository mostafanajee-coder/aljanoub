{% extends "layouts.master" %}

{% block content %}
<style>
  :root {
    --primary-color: #3b2818; /* Rich Coffee Brown */
    --secondary-color: #1e3b2b; /* Deep Green */
    --accent-color: #cda434; /* Premium Gold */
    --accent-light: #fdfaf3; /* Very Light Gold/Cream */
    --accent-glow: rgba(205, 164, 52, 0.2);
    --bg-main: #fcfbfa; /* Slightly warmer white/cream */
    --bg-alt: #f4f1eb; /* Soft contrast background */
    --white: #ffffff;
    --text-dark: #1a1a1a;
    --text-light: #5a5a5a;
    --border-color: #e8e4df;
    --shadow-sm: 0 4px 15px rgba(0, 0, 0, 0.03);
    --shadow-md: 0 10px 30px rgba(0, 0, 0, 0.06);
    --shadow-hover: 0 15px 40px rgba(30, 59, 43, 0.08);
    --shadow-gold: 0 10px 25px rgba(205, 164, 52, 0.15);
    --radius-md: 12px;
    --radius-lg: 20px;
    --transition: all 0.35s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  
  /* --- Temporary Hiding of Salla Demo Artifacts --- */
  header, .store-header, 
  footer, .store-footer, 
  .salla-demo-ribbon, 
  .demo-badge, 
  .demo-notice,
  #twilight-toolbar,
  .twilight-toolbar {
    display: none !important;
  }
  body { padding-top: 0 !important; }

  /* --- Global Settings --- */
  .v5-home-wrapper {
    font-family: 'Tajawal', 'Cairo', sans-serif;
    background-color: var(--bg-main);
    color: var(--text-dark);
    line-height: 1.6;
    overflow-x: hidden;
  }
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .section-padding { padding: 60px 0; }
  
  .section-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .section-title {
    font-size: 2.2rem;
    color: var(--secondary-color);
    font-weight: 900;
    margin-bottom: 10px;
    display: inline-block;
  }
  .title-accent {
    display: block;
    width: 50px;
    height: 3px;
    background-color: var(--accent-color);
    margin: 15px auto 0;
    border-radius: 4px;
  }
  .section-subtitle {
    color: var(--text-light);
    font-size: 1.1rem;
    max-width: 550px;
    margin: 10px auto 0;
  }

  /* --- V5 Concept Header --- */
  .concept-header {
    background-color: var(--white);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid var(--border-color);
    box-shadow: var(--shadow-sm);
  }
  .concept-top-bar {
    background-color: var(--primary-color);
    color: var(--accent-light);
    font-size: 0.85rem;
    font-weight: 700;
    padding: 8px 0;
    text-align: center;
    letter-spacing: 0.5px;
  }
  .concept-nav-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 80px;
  }
  .concept-logo {
    font-size: 1.8rem;
    font-weight: 900;
    color: var(--secondary-color);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .concept-logo span { color: var(--accent-color); }
  .concept-logo-icon {
    width: 35px; height: 35px;
    background: linear-gradient(135deg, var(--accent-color), #f3d47c);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    color: var(--white); font-size: 1.2rem;
    box-shadow: var(--shadow-gold);
  }
  .concept-links {
    display: flex;
    gap: 25px;
    list-style: none;
    margin: 0; padding: 0;
  }
  .concept-links a {
    text-decoration: none;
    color: var(--text-dark);
    font-weight: 700;
    font-size: 1.05rem;
    transition: var(--transition);
    padding: 5px 0;
  }
  .concept-links a:hover {
    color: var(--accent-color);
  }
  .concept-actions {
    display: flex;
    align-items: center;
    gap: 15px;
  }
  .concept-search-pill {
    background-color: var(--bg-alt);
    border-radius: 50px;
    padding: 10px 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--text-light);
    font-size: 0.9rem;
    border: 1px solid transparent;
    transition: var(--transition);
    cursor: text;
  }
  .concept-search-pill:hover {
    border-color: var(--border-color);
    background-color: var(--white);
  }
  .concept-icon-btn {
    width: 42px; height: 42px;
    display: flex; align-items: center; justify-content: center;
    background-color: var(--white);
    border: 1px solid var(--border-color);
    border-radius: 50%;
    color: var(--text-dark);
    text-decoration: none;
    font-size: 1.1rem;
    transition: var(--transition);
    position: relative;
  }
  .concept-icon-btn:hover {
    border-color: var(--accent-color);
    color: var(--accent-color);
  }
  .cart-badge {
    position: absolute;
    top: -5px; right: -5px;
    background-color: var(--accent-color);
    color: var(--white);
    width: 20px; height: 20px;
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: bold;
    display: flex; align-items: center; justify-content: center;
  }

  /* --- V5 Luxury Hero Section --- */
  .hero-section {
    position: relative;
    background: var(--bg-main);
    padding: 60px 20px 80px;
    overflow: hidden;
  }
  .hero-bg-accent {
    position: absolute;
    top: -100px; left: -100px;
    width: 800px; height: 800px;
    background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
    border-radius: 50%;
    z-index: 1;
    opacity: 0.6;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 50px;
    align-items: center;
    position: relative;
    z-index: 2;
  }
  .hero-content { text-align: right; }
  .hero-badge {
    display: inline-flex;
    align-items: center; gap: 8px;
    background-color: var(--white);
    padding: 8px 16px;
    border-radius: 30px;
    font-size: 0.9rem; font-weight: 700;
    color: var(--accent-color);
    border: 1px solid var(--border-color);
    margin-bottom: 25px;
    box-shadow: var(--shadow-sm);
  }
  .hero-title {
    font-size: 4rem;
    font-weight: 900;
    color: var(--secondary-color);
    margin-bottom: 20px;
    line-height: 1.15;
  }
  .hero-title span {
    color: var(--primary-color);
    display: block;
    font-size: 3rem;
  }
  .hero-subtitle {
    font-size: 1.25rem;
    margin-bottom: 35px;
    color: var(--text-light);
    line-height: 1.8;
  }
  .hero-actions { display: flex; gap: 15px; }
  .btn-primary {
    background-color: var(--secondary-color);
    color: var(--white);
    padding: 15px 35px;
    border-radius: 50px;
    font-weight: 800; font-size: 1.1rem;
    text-decoration: none;
    transition: var(--transition);
    box-shadow: var(--shadow-md);
  }
  .btn-primary:hover {
    background-color: var(--primary-color);
    transform: translateY(-3px);
  }
  .btn-secondary {
    background-color: var(--white);
    color: var(--secondary-color);
    padding: 15px 35px;
    border-radius: 50px;
    font-weight: 800; font-size: 1.1rem;
    text-decoration: none;
    border: 1px solid var(--border-color);
    transition: var(--transition);
  }
  .btn-secondary:hover {
    border-color: var(--accent-color);
    color: var(--accent-color);
  }
  
  /* Hero Visual Composition */
  .hero-composition {
    position: relative;
    height: 550px;
    display: flex; align-items: center; justify-content: center;
  }
  .comp-bg {
    position: absolute;
    width: 400px; height: 400px;
    background: linear-gradient(135deg, var(--white), var(--bg-alt));
    border-radius: 50%;
    box-shadow: var(--shadow-md);
    border: 1px solid var(--white);
  }
  .comp-card {
    position: absolute;
    background: var(--white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-hover);
    padding: 20px;
    border: 1px solid rgba(255,255,255,0.8);
    backdrop-filter: blur(10px);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    transition: var(--transition);
  }
  .comp-card:hover { transform: translateY(-10px) scale(1.05); z-index: 10; }
  
  /* Composition Pieces */
  .comp-main {
    width: 260px; height: 300px;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    background: linear-gradient(to bottom, var(--white), #f9f6f0);
  }
  .comp-main .art-coffee {
    width: 140px; height: 140px;
    background: radial-gradient(circle at 30% 30%, #5c3a21, var(--primary-color));
    border-radius: 50%;
    border: 8px solid var(--white);
    box-shadow: 0 15px 25px rgba(59,40,24,0.3);
    position: relative;
    margin-bottom: 20px;
  }
  .comp-main .art-coffee::after { /* cup handle */
    content: ''; position: absolute;
    right: -25px; top: 35px; width: 40px; height: 60px;
    border: 8px solid var(--white); border-radius: 20px; z-index: -1;
  }
  
  .comp-float-1 {
    width: 180px; height: 200px;
    top: 10%; right: 0; z-index: 2;
    animation: float 8s ease-in-out infinite;
  }
  .comp-float-1 .art-dates {
    width: 100px; height: 80px;
    background: #4a2c11; border-radius: 50px 50px 10px 10px;
    position: relative; margin-bottom: 15px;
  }
  .comp-float-1 .art-dates::before { /* dates inside */
    content: '🌰'; font-size: 2.5rem; position: absolute; top: -20px; left: 15px;
    filter: drop-shadow(0 5px 5px rgba(0,0,0,0.3));
  }

  .comp-float-2 {
    width: 200px; height: 140px;
    bottom: 10%; left: 0; z-index: 4;
    animation: float 6s ease-in-out infinite 1s;
    flex-direction: row; gap: 15px; padding: 15px;
  }
  .comp-float-2 .art-saffron {
    width: 60px; height: 60px;
    background: var(--accent-light); border-radius: 50%;
    border: 2px solid var(--accent-color);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.8rem;
  }

  .comp-label {
    font-weight: 800; color: var(--secondary-color); font-size: 1.1rem;
    text-align: center;
  }
  .comp-sub { font-size: 0.85rem; color: var(--accent-color); font-weight: 700; }

  /* --- Premium Category Grid --- */
  .cat-grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;
  }
  .cat-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: 30px 20px;
    text-align: center;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
    border: 1px solid var(--border-color);
    text-decoration: none; display: block;
  }
  .cat-card:hover {
    transform: translateY(-5px); box-shadow: var(--shadow-md);
    border-color: var(--accent-color);
  }
  .cat-icon-area {
    width: 80px; height: 80px; margin: 0 auto 15px;
    background: var(--bg-alt); border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 2.2rem; transition: var(--transition);
  }
  .cat-card:hover .cat-icon-area {
    background: var(--accent-light); color: var(--accent-color);
    transform: scale(1.1);
  }
  .cat-name { font-weight: 800; color: var(--secondary-color); font-size: 1.1rem; }

  /* --- Premium Product Cards --- */
  .product-grid {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 25px;
  }
  .product-card {
    background: var(--white); border-radius: var(--radius-lg);
    overflow: hidden; box-shadow: var(--shadow-sm);
    transition: var(--transition); border: 1px solid var(--border-color);
    display: flex; flex-direction: column; position: relative;
  }
  .product-card:hover {
    transform: translateY(-8px); box-shadow: var(--shadow-hover);
  }
  .p-badge {
    position: absolute; top: 15px; right: 15px;
    background: var(--accent-color); color: var(--white);
    padding: 5px 12px; border-radius: 20px;
    font-size: 0.8rem; font-weight: 800; z-index: 2;
  }
  .p-badge.new { background: var(--secondary-color); }
  
  /* CSS-only Product Visuals */
  .p-visual {
    height: 240px; background: var(--bg-alt);
    display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden;
  }
  .p-visual::after { /* soft spotlight */
    content: ''; position: absolute; width: 150px; height: 150px;
    background: var(--white); border-radius: 50%; filter: blur(20px); opacity: 0.6;
  }
  .art-box {
    width: 120px; height: 140px; border-radius: 10px;
    box-shadow: 0 10px 20px rgba(0,0,0,0.1); position: relative; z-index: 1;
    display: flex; align-items: center; justify-content: center;
    font-size: 3rem; color: var(--white);
  }
  .art-coffee-bag { background: linear-gradient(135deg, #2c1b10, #4a2c11); border-radius: 5px 5px 15px 15px; }
  .art-dates-box { background: linear-gradient(135deg, #a67c00, #bf953f); height: 80px; width: 140px; }
  .art-cardamom-jar { background: linear-gradient(to bottom, #d4ebd0, #8cb585); width: 90px; border-radius: 40px; }
  .art-saffron-tin { background: linear-gradient(135deg, #e31b23, #a10f16); width: 100px; height: 100px; border-radius: 50%; }
  .art-grinder { background: linear-gradient(135deg, #333, #111); width: 90px; height: 160px; border-radius: 10px; }
  .art-tea { background: linear-gradient(135deg, #2b4522, #1a2e13); }
  .art-hospitality { background: linear-gradient(135deg, #f0f0f0, #d4d4d4); border-radius: 50%; width: 130px; height: 130px; border: 4px solid var(--accent-color);}
  .art-camping { background: linear-gradient(135deg, #8b7355, #5c4a3d); border-radius: 20px; height: 110px; width: 150px; }

  .p-label {
    position: absolute; bottom: 20px; background: rgba(255,255,255,0.9);
    padding: 4px 10px; border-radius: 4px; font-size: 0.75rem; font-weight: bold; color: var(--text-dark);
  }

  .p-info { padding: 25px 20px; display: flex; flex-direction: column; flex-grow: 1; }
  .p-title { font-size: 1.15rem; color: var(--text-dark); font-weight: 800; margin-bottom: 8px; line-height: 1.4; }
  .p-rate { color: var(--accent-color); font-size: 0.85rem; margin-bottom: 15px; }
  .p-footer { display: flex; justify-content: space-between; align-items: flex-end; margin-top: auto; }
  .p-price { color: var(--secondary-color); font-weight: 900; font-size: 1.4rem; }
  .p-price span { font-size: 0.85rem; color: var(--text-light); }
  .p-btn {
    width: 40px; height: 40px; border-radius: 50%;
    background: var(--bg-alt); color: var(--secondary-color);
    display: flex; align-items: center; justify-content: center;
    border: none; cursor: pointer; transition: var(--transition);
    font-size: 1.1rem;
  }
  .product-card:hover .p-btn { background: var(--secondary-color); color: var(--white); transform: scale(1.1); }

  /* --- Luxury Promo Banner --- */
  .promo-section { padding: 20px 0; }
  .promo-banner {
    background: var(--primary-color);
    border-radius: var(--radius-lg);
    padding: 70px 40px;
    text-align: center;
    color: var(--white);
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  .promo-pattern {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    background-image: radial-gradient(rgba(205,164,52,0.15) 2px, transparent 2px);
    background-size: 40px 40px; opacity: 0.5;
  }
  .promo-content { position: relative; z-index: 2; max-width: 700px; margin: 0 auto; }
  .promo-title { font-size: 2.8rem; color: var(--accent-color); font-weight: 900; margin-bottom: 20px; }
  .promo-text { font-size: 1.2rem; opacity: 0.9; margin-bottom: 30px; line-height: 1.7; }
  .promo-btn {
    background: var(--accent-color); color: var(--white);
    padding: 14px 40px; border-radius: 50px; font-weight: 800; font-size: 1.1rem;
    display: inline-block; text-decoration: none; transition: var(--transition);
  }
  .promo-btn:hover { background: var(--white); color: var(--primary-color); }

  /* --- Story Section --- */
  .story-container {
    display: grid; grid-template-columns: 1fr 1fr;
    background: var(--white); border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm); overflow: hidden; border: 1px solid var(--border-color);
  }
  .story-text { padding: 60px 50px; display: flex; flex-direction: column; justify-content: center; }
  .story-text h2 { font-size: 2.5rem; color: var(--secondary-color); font-weight: 900; margin-bottom: 20px; }
  .story-text h2 span { color: var(--accent-color); }
  .story-text p { font-size: 1.1rem; color: var(--text-light); line-height: 1.8; margin-bottom: 20px; }
  
  .story-img {
    background: linear-gradient(135deg, var(--bg-alt), #e5e0d8);
    display: flex; align-items: center; justify-content: center; position: relative; min-height: 400px;
  }
  .story-seal {
    width: 220px; height: 220px; border-radius: 50%;
    background: var(--white); border: 4px solid var(--accent-color);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    box-shadow: var(--shadow-md); position: relative;
  }
  .story-seal::before {
    content: ''; position: absolute; top: -10px; left: -10px; right: -10px; bottom: -10px;
    border: 1px dashed var(--accent-color); border-radius: 50%; animation: rotateBg 20s linear infinite;
  }
  .seal-icon { font-size: 3rem; color: var(--primary-color); margin-bottom: 10px; }
  .seal-text { font-weight: 900; color: var(--secondary-color); font-size: 1.2rem; }

  /* --- Brands Section --- */
  .brands-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px; }
  .brand-box {
    background: var(--white); border: 1px solid var(--border-color);
    border-radius: var(--radius-md); padding: 30px 15px;
    text-align: center; transition: var(--transition); position: relative; overflow: hidden;
  }
  .brand-box::before {
    content: ''; position: absolute; top: 0; right: 0; width: 30px; height: 30px;
    background: var(--accent-color); transform: translate(50%, -50%) rotate(45deg);
  }
  .brand-box:hover { border-color: var(--accent-color); box-shadow: var(--shadow-sm); transform: translateY(-3px); }
  .brand-ico { font-size: 2.2rem; margin-bottom: 10px; color: var(--primary-color); }
  .brand-txt { font-weight: 800; color: var(--text-dark); font-size: 1rem; }

  /* --- Trust Section --- */
  .trust-wrap {
    background: var(--secondary-color); border-radius: var(--radius-lg);
    padding: 40px; color: var(--white); margin-bottom: 40px;
  }
  .trust-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 30px; }
  .trust-box { display: flex; align-items: center; gap: 15px; }
  .t-icon {
    width: 60px; height: 60px; border-radius: 12px;
    background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.6rem; color: var(--accent-color); flex-shrink: 0;
  }
  .t-info h4 { font-weight: 800; font-size: 1.05rem; margin-bottom: 4px; }
  .t-info p { font-size: 0.85rem; color: rgba(255,255,255,0.7); }

  /* --- Concept Footer --- */
  .concept-footer {
    background: var(--white); border-top: 1px solid var(--border-color);
    padding: 60px 20px 20px;
  }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1.5fr; gap: 40px; max-width: 1280px; margin: 0 auto; }
  .f-col h4 { font-size: 1.2rem; font-weight: 900; color: var(--secondary-color); margin-bottom: 20px; }
  .f-logo { font-size: 2rem; font-weight: 900; color: var(--secondary-color); text-decoration: none; display: inline-block; margin-bottom: 15px; }
  .f-logo span { color: var(--accent-color); }
  .f-desc { color: var(--text-light); font-size: 0.95rem; line-height: 1.7; }
  .f-links { list-style: none; padding: 0; margin: 0; }
  .f-links li { margin-bottom: 12px; }
  .f-links a { color: var(--text-light); text-decoration: none; transition: var(--transition); font-weight: 600; font-size: 0.95rem; }
  .f-links a:hover { color: var(--accent-color); padding-right: 5px; }
  .f-contact p { color: var(--text-light); margin-bottom: 12px; font-size: 0.95rem; font-weight: 600; display: flex; align-items: center; gap: 8px; }
  .f-bottom {
    max-width: 1280px; margin: 40px auto 0; padding-top: 20px;
    border-top: 1px solid var(--border-color); text-align: center;
    color: var(--text-light); font-size: 0.9rem; font-weight: 600;
  }

  /* --- Responsive --- */
  @media (max-width: 1100px) {
    .hero-title { font-size: 3rem; } .hero-title span { font-size: 2.2rem; }
    .hero-composition { transform: scale(0.85); transform-origin: left center; }
    .product-grid { grid-template-columns: repeat(3, 1fr); }
    .cat-grid { grid-template-columns: repeat(4, 1fr); } /* keep 4 on tablet if possible */
    .brands-grid { grid-template-columns: repeat(3, 1fr); }
    .trust-grid { grid-template-columns: repeat(2, 1fr); }
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 850px) {
    .concept-links { display: none; }
    .hero-grid { grid-template-columns: 1fr; text-align: center; gap: 30px; }
    .hero-content { text-align: center; }
    .hero-actions { justify-content: center; }
    .hero-composition { transform: scale(0.9); transform-origin: center; height: 400px; }
    .cat-grid { grid-template-columns: repeat(2, 1fr); }
    .product-grid { grid-template-columns: repeat(2, 1fr); }
    .story-container { grid-template-columns: 1fr; }
    .story-img { min-height: 300px; }
  }
  @media (max-width: 500px) {
    .hero-actions { flex-direction: column; }
    .hero-composition { transform: scale(0.7); height: 320px; }
