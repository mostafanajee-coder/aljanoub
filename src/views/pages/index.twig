{% extends "layouts.master" %}

{% block content %}
<style>
  :root {
    --primary-color: #3b2818; /* Rich Coffee Brown */
    --secondary-color: #1e3b2b; /* Deep Green */
    --accent-color: #cda434; /* Premium Gold */
    --accent-light: #f5eedc; /* Light Gold/Cream */
    --bg-main: #faf8f5; /* Very Light Cream */
    --white: #ffffff;
    --text-dark: #222222;
    --text-light: #666666;
    --border-color: #eaeaea;
    --shadow-soft: 0 8px 25px rgba(0, 0, 0, 0.04);
    --shadow-hover: 0 15px 35px rgba(30, 59, 43, 0.1);
    --radius-md: 12px;
    --radius-lg: 20px;
    --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  }
  
  /* --- 1. Temporary Hiding of Salla Demo Artifacts --- */
  /* Temporary for coded concept preview only. */
  header, .store-header, 
  footer, .store-footer, 
  .salla-demo-ribbon, 
  .demo-badge, 
  .demo-notice,
  #twilight-toolbar,
  .twilight-toolbar {
    display: none !important;
  }
  
  /* Reset body padding if Salla theme added any for fixed header */
  body {
    padding-top: 0 !important;
  }

  /* --- Homepage Global Styles --- */
  .v4-home-wrapper {
    font-family: 'Tajawal', 'Cairo', sans-serif;
    background-color: var(--bg-main);
    color: var(--text-dark);
    line-height: 1.6;
    overflow-x: hidden;
  }

  .container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .section-padding {
    padding: 70px 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: 50px;
  }
  .section-title {
    font-size: 2.5rem;
    color: var(--secondary-color);
    font-weight: 900;
    margin-bottom: 15px;
    position: relative;
    display: inline-block;
  }
  .section-title::after {
    content: '';
    position: absolute;
    bottom: -12px;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 4px;
    background-color: var(--accent-color);
    border-radius: 4px;
  }
  .section-subtitle {
    color: var(--text-light);
    font-size: 1.15rem;
    max-width: 600px;
    margin: 15px auto 0;
  }

  /* --- Custom V4 Concept Header --- */
  .concept-header {
    background-color: var(--white);
    box-shadow: 0 2px 15px rgba(0,0,0,0.05);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 3px solid var(--accent-color);
  }
  .concept-top-bar {
    background-color: var(--secondary-color);
    color: var(--white);
    font-size: 0.9rem;
    padding: 8px 0;
    text-align: center;
  }
  .concept-nav-wrapper {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 0;
  }
  .concept-logo {
    font-size: 1.8rem;
    font-weight: 900;
    color: var(--primary-color);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .concept-logo span {
    color: var(--accent-color);
  }
  .concept-links {
    display: flex;
    gap: 25px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .concept-links a {
    text-decoration: none;
    color: var(--text-dark);
    font-weight: 700;
    font-size: 1.05rem;
    transition: var(--transition);
  }
  .concept-links a:hover {
    color: var(--accent-color);
  }
  .concept-actions {
    display: flex;
    align-items: center;
    gap: 15px;
  }
  .concept-search-pill {
    background-color: var(--bg-main);
    border-radius: 50px;
    padding: 8px 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--text-light);
    font-size: 0.9rem;
    border: 1px solid var(--border-color);
  }
  .concept-icon-btn {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--bg-main);
    border-radius: 50%;
    color: var(--primary-color);
    text-decoration: none;
    font-size: 1.2rem;
    transition: var(--transition);
  }
  .concept-icon-btn:hover {
    background-color: var(--accent-light);
    color: var(--accent-color);
  }

  /* --- V4 Two-Column Hero Section --- */
  .hero-section {
    position: relative;
    background: linear-gradient(135deg, #112218 0%, var(--secondary-color) 100%);
    color: var(--white);
    padding: 90px 20px;
    overflow: hidden;
  }
  .hero-decoration-glow {
    position: absolute;
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(205,164,52,0.12) 0%, rgba(205,164,52,0) 65%);
    border-radius: 50%;
    top: 50%;
    left: -150px;
    transform: translateY(-50%);
    z-index: 1;
  }
  .hero-pattern {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background-image: radial-gradient(var(--accent-color) 1px, transparent 1px);
    background-size: 30px 30px;
    opacity: 0.05;
    z-index: 1;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 60px;
    align-items: center;
    position: relative;
    z-index: 2;
  }
  .hero-content {
    text-align: right;
  }
  .hero-title {
    font-size: 4rem;
    font-weight: 900;
    color: var(--white);
    margin-bottom: 20px;
    line-height: 1.2;
    text-shadow: 0 5px 15px rgba(0,0,0,0.3);
  }
  .hero-title span {
    color: var(--accent-color);
    display: block;
    font-size: 3.2rem;
    margin-top: 10px;
  }
  .hero-subtitle {
    font-size: 1.3rem;
    margin-bottom: 40px;
    color: #f0f0f0;
    line-height: 1.8;
    max-width: 90%;
  }
  .hero-actions {
    display: flex;
    gap: 20px;
  }
  .btn-primary, .btn-outline {
    padding: 16px 40px;
    border-radius: 50px;
    font-weight: 800;
    font-size: 1.15rem;
    text-decoration: none;
    transition: var(--transition);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .btn-primary {
    background-color: var(--accent-color);
    color: var(--primary-color);
    box-shadow: 0 10px 30px rgba(205, 164, 52, 0.3);
  }
  .btn-primary:hover {
    background-color: var(--white);
    transform: translateY(-4px);
    box-shadow: 0 15px 35px rgba(255, 255, 255, 0.3);
  }
  .btn-outline {
    background-color: rgba(255,255,255,0.05);
    color: var(--white);
    border: 2px solid var(--accent-color);
    backdrop-filter: blur(5px);
  }
  .btn-outline:hover {
    background-color: var(--accent-color);
    color: var(--primary-color);
  }
  
  /* Hero Visual Card */
  .hero-visual {
    position: relative;
    height: 480px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(205, 164, 52, 0.4);
    border-radius: 30px;
    backdrop-filter: blur(15px);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 30px 60px rgba(0,0,0,0.4), inset 0 0 40px rgba(205,164,52,0.1);
  }
  .hero-visual-inner {
    position: relative;
    width: 100%;
    height: 100%;
  }
  .shape-coffee {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 9rem;
    color: var(--accent-color);
    filter: drop-shadow(0 15px 30px rgba(0,0,0,0.5));
    animation: float 6s ease-in-out infinite;
  }
  .shape-badge {
    position: absolute;
    background: var(--white);
    color: var(--primary-color);
    padding: 16px 28px;
    border-radius: 40px;
    font-weight: 900;
    font-size: 1.1rem;
    box-shadow: 0 15px 30px rgba(0,0,0,0.25);
    display: flex;
    align-items: center;
    gap: 12px;
    border: 2px solid var(--accent-light);
  }
  .shape-badge-1 { top: 50px; right: -30px; animation: float 5s ease-in-out infinite 1s; }
  .shape-badge-2 { bottom: 70px; left: -40px; animation: float 7s ease-in-out infinite 2s; }
  
  @keyframes float {
    0% { transform: translate(-50%, -50%) translateY(0px); }
    50% { transform: translate(-50%, -50%) translateY(-20px); }
    100% { transform: translate(-50%, -50%) translateY(0px); }
  }

  /* --- Responsive Categories --- */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 25px;
  }
  .cat-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: 35px 20px;
    text-align: center;
    box-shadow: var(--shadow-soft);
    transition: var(--transition);
    border: 1px solid var(--border-color);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .cat-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: linear-gradient(90deg, var(--accent-color), #f3d47c);
    transform: scaleX(0);
    transition: var(--transition);
  }
  .cat-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-hover);
    border-color: transparent;
  }
  .cat-card:hover::after {
    transform: scaleX(1);
  }
  .cat-icon-wrap {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, var(--bg-main), #f0ebd8);
    border: 2px solid var(--border-color);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
    font-size: 2.6rem;
    color: var(--primary-color);
    transition: var(--transition);
  }
  .cat-card:hover .cat-icon-wrap {
    background: var(--accent-light);
    border-color: var(--accent-color);
    color: var(--secondary-color);
    transform: scale(1.1) rotate(5deg);
  }
  .cat-name {
    font-weight: 900;
    color: var(--secondary-color);
    font-size: 1.15rem;
  }

  /* --- Premium Product Cards --- */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
  }
  .product-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
    transition: var(--transition);
    border: 1px solid var(--border-color);
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .product-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-hover);
    border-color: var(--accent-light);
  }
  .product-badge {
    position: absolute;
    top: 15px;
    right: 15px;
    background-color: var(--secondary-color);
    color: var(--white);
    padding: 8px 16px;
    border-radius: 30px;
    font-size: 0.85rem;
    font-weight: 800;
    z-index: 2;
    box-shadow: 0 5px 15px rgba(0,0,0,0.15);
  }
  .product-img-block {
    height: 280px;
    background: radial-gradient(circle, var(--white) 0%, #f4eee1 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border-color);
  }
  .product-img-block::before {
    content: '';
    position: absolute;
    width: 180px;
    height: 180px;
    background: var(--white);
    border-radius: 50%;
    opacity: 0.7;
    box-shadow: 0 0 40px rgba(205,164,52,0.1);
  }
  .product-icon-art {
    font-size: 6.5rem;
    z-index: 1;
    filter: drop-shadow(0 20px 20px rgba(0,0,0,0.15));
    transition: var(--transition);
  }
  .product-card:hover .product-icon-art {
    transform: scale(1.15) translateY(-5px);
  }
  .product-info {
    padding: 30px 25px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }
  .product-title {
    font-size: 1.2rem;
    color: var(--secondary-color);
    font-weight: 900;
    margin-bottom: 10px;
    line-height: 1.4;
  }
  .product-rating {
    color: var(--accent-color);
    font-size: 0.9rem;
    margin-bottom: 15px;
    letter-spacing: 2px;
  }
  .product-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
  }
  .product-price-block {
    display: flex;
    flex-direction: column;
  }
  .product-price {
    color: var(--primary-color);
    font-weight: 900;
    font-size: 1.5rem;
  }
  .product-price span {
    font-size: 0.9rem;
    color: var(--text-light);
    font-weight: 700;
    margin-right: 4px;
  }
  .product-add-btn {
    background-color: var(--bg-main);
    color: var(--secondary-color);
    border: 2px solid var(--border-color);
    padding: 10px 20px;
    border-radius: 30px;
    font-weight: 800;
    font-size: 0.95rem;
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    transition: var(--transition);
  }
  .product-card:hover .product-add-btn {
    background-color: var(--accent-color);
    color: var(--primary-color);
    border-color: var(--accent-color);
    box-shadow: 0 5px 15px rgba(205, 164, 52, 0.3);
  }

  /* --- Wide Promo Banner --- */
  .promo-banner-wrapper {
    padding: 30px 0;
  }
  .wide-promo-banner {
    background: linear-gradient(135deg, #2a1b10 0%, var(--primary-color) 100%);
    border-radius: var(--radius-lg);
    padding: 80px 50px;
    text-align: center;
    color: var(--white);
    position: relative;
    overflow: hidden;
    box-shadow: 0 25px 50px rgba(59, 40, 24, 0.3);
    border: 2px solid rgba(205, 164, 52, 0.3);
  }
  .wide-promo-banner::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(205,164,52,0.15) 0%, transparent 60%);
    animation: rotateBg 25s linear infinite;
  }
  @keyframes rotateBg {
    100% { transform: rotate(360deg); }
  }
  .promo-banner-content {
    position: relative;
    z-index: 2;
    max-width: 850px;
    margin: 0 auto;
  }
  .promo-banner-title {
    font-size: 3.2rem;
    color: var(--accent-color);
    font-weight: 900;
    margin-bottom: 25px;
    line-height: 1.2;
  }
  .promo-banner-text {
    font-size: 1.3rem;
    opacity: 0.95;
    margin-bottom: 35px;
    line-height: 1.8;
  }
  .promo-banner-btn {
    background-color: var(--white);
    color: var(--primary-color);
    padding: 16px 45px;
    border-radius: 50px;
    font-weight: 900;
    font-size: 1.15rem;
    text-decoration: none;
    display: inline-block;
    transition: var(--transition);
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
  }
  .promo-banner-btn:hover {
    background-color: var(--accent-color);
    color: var(--white);
    transform: translateY(-3px);
  }

  /* --- Story Section --- */
  .story-wrapper {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 0;
    background-color: var(--white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    border: 1px solid var(--border-color);
  }
  .story-content {
    padding: 80px 60px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .story-content h2 {
    font-size: 2.8rem;
    color: var(--secondary-color);
    font-weight: 900;
    margin-bottom: 30px;
    position: relative;
  }
  .story-content h2::after {
    content: '';
    display: block;
    width: 70px;
    height: 5px;
    background-color: var(--accent-color);
    margin-top: 15px;
    border-radius: 3px;
  }
  .story-content p {
    font-size: 1.2rem;
    color: var(--text-light);
    line-height: 1.9;
    margin-bottom: 25px;
  }
  .story-visual {
    background: linear-gradient(135deg, var(--accent-light), #e3dac1);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: 50px;
  }
  .story-visual-card {
    background: var(--white);
    padding: 50px;
    border-radius: 50%;
    width: 320px;
    height: 320px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    box-shadow: 0 25px 50px rgba(0,0,0,0.1);
    border: 3px solid var(--accent-color);
    position: relative;
    z-index: 2;
  }
  .story-visual-card::before {
    content: '';
    position: absolute;
    top: -15px; left: -15px; right: -15px; bottom: -15px;
    border: 1px dashed var(--accent-color);
    border-radius: 50%;
    opacity: 0.5;
    animation: rotateBg 30s linear infinite;
  }
  .story-visual-icon {
    font-size: 6rem;
    margin-bottom: 15px;
  }
  .story-visual-text {
    font-size: 1.6rem;
    font-weight: 900;
    color: var(--primary-color);
  }

  /* --- Premium Brand Cards --- */
  .brands-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 25px;
  }
  .brand-card {
    background: linear-gradient(to bottom, var(--white), var(--bg-main));
    padding: 35px 20px;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    border: 1px solid var(--border-color);
    text-align: center;
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .brand-card:hover {
    border-color: var(--accent-color);
    transform: translateY(-8px);
    box-shadow: var(--shadow-hover);
  }
  .brand-icon {
    font-size: 3rem;
    color: var(--accent-color);
    margin-bottom: 15px;
    filter: drop-shadow(0 5px 10px rgba(205,164,52,0.2));
  }
  .brand-name {
    font-weight: 900;
    font-size: 1.2rem;
    color: var(--secondary-color);
  }

  /* --- Trust Features (Compact & Premium) --- */
  .features-container {
    background-color: var(--secondary-color);
    border-radius: var(--radius-lg);
    padding: 60px 50px;
    color: var(--white);
    box-shadow: 0 20px 40px rgba(30, 59, 43, 0.2);
    position: relative;
    overflow: hidden;
  }
  .features-container::after {
    content: '';
    position: absolute;
    top: 0; right: 0; bottom: 0; left: 0;
    background: url('data:image/svg+xml;utf8,<svg width="20" height="20" xmlns="http://www.w3.org/2000/svg"><circle cx="2" cy="2" r="2" fill="%23cda434" fill-opacity="0.1"/></svg>');
    opacity: 0.5;
  }
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    position: relative;
    z-index: 2;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .trust-icon-wrap {
    width: 70px;
    height: 70px;
    background: linear-gradient(135deg, rgba(205,164,52,0.2), rgba(205,164,52,0.05));
    border-radius: 16px;
    display: flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    color: var(--accent-color);
    border: 1px solid rgba(205, 164, 52, 0.4);
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
  }
  .trust-content {
    text-align: right;
  }
  .trust-title {
    font-weight: 900;
    font-size: 1.15rem;
    margin-bottom: 6px;
    color: var(--white);
  }
  .trust-desc {
    font-size: 0.9rem;
    color: #d0d0d0;
  }

  /* --- Custom V4 Concept Footer --- */
  .concept-footer {
    background-color: #111a14;
    color: var(--white);
    padding: 80px 20px 40px;
    border-top: 5px solid var(--accent-color);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 50px;
    max-width: 1300px;
    margin: 0 auto;
  }
  .footer-col h4 {
    color: var(--accent-color);
    font-size: 1.4rem;
    font-weight: 900;
    margin-bottom: 25px;
  }
  .footer-logo {
    font-size: 2.2rem;
    font-weight: 900;
    color: var(--white);
    margin-bottom: 20px;
    display: inline-block;
    text-decoration: none;
  }
  .footer-logo span { color: var(--accent-color); }
  .footer-desc {
    color: #a0a0a0;
    line-height: 1.8;
    margin-bottom: 25px;
  }
  .footer-links {
    list-style: none;
    padding: 0; margin: 0;
  }
  .footer-links li { margin-bottom: 15px; }
  .footer-links a {
    color: #d0d0d0;
    text-decoration: none;
    transition: var(--transition);
  }
  .footer-links a:hover {
    color: var(--accent-color);
    padding-right: 5px;
  }
  .footer-contact p {
    color: #d0d0d0;
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .footer-bottom {
    max-width: 1300px;
    margin: 50px auto 0;
    padding-top: 25px;
    border-top: 1px solid rgba(255,255,255,0.1);
    text-align: center;
    color: #888;
    font-size: 0.9rem;
  }

  /* --- Responsive Breakpoints --- */
  @media (max-width: 1200px) {
    .product-grid { grid-template-columns: repeat(3, 1fr); }
    .brands-grid { grid-template-columns: repeat(3, 1fr); }
    .trust-grid { grid-template-columns: repeat(2, 1fr); }
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
  }
  
  @media (max-width: 992px) {
    .concept-links { display: none; }
    .hero-grid { grid-template-columns: 1fr; text-align: center; gap: 40px; }
    .hero-content { text-align: center; }
    .hero-actions { justify-content: center; }
    .hero-visual { height: 400px; max-width: 500px; margin: 0 auto; }
    .cat-grid { grid-template-columns: repeat(2, 1fr); }
    .story-wrapper { grid-template-columns: 1fr; }
    .story-visual { min-height: 350px; }
    .product-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .section-padding { padding: 50px 0; }
    .hero-section { padding: 60px 20px; }
    .hero-title { font-size: 2.8rem; }
    .hero-actions { flex-direction: column; }
    .wide-promo-banner { padding: 60px 20px; }
    .promo-banner-title { font-size: 2.4rem; }
    .story-content { padding: 40px 20px; }
    .story-content h2 { font-size: 2.2rem; }
    .brands-grid { grid-template-columns: repeat(2, 1fr); }
    .trust-grid { grid-template-columns: 1fr; }
    .trust-item { flex-direction: column; text-align: center; }
    .product-grid { grid-template-columns: repeat(2, 1fr); gap: 15px; }
    .product-img-block { height: 200px; }
    .product-icon-art { font-size: 4.5rem; }
    .product-info { padding: 20px 15px; }
    .footer-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .cat-grid { grid-template-columns: repeat(2, 1fr); gap: 15px; }
    .product-grid { grid-template-columns: 1fr; }
  }
</style>

