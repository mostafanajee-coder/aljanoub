{% extends "layouts.master" %}

{% block content %}
<style>
  :root {
    --primary-color: #4b3621; /* Coffee Brown */
    --secondary-color: #2b4f3b; /* Dark Green */
    --accent-color: #d4af37; /* Gold */
    --bg-light: #fdfbf7; /* Cream */
    --text-dark: #1a1a1a;
  }
  
  .home-wrapper {
    font-family: 'Tajawal', 'Cairo', sans-serif;
    background-color: var(--bg-light);
    color: var(--text-dark);
    line-height: 1.6;
    overflow-x: hidden;
  }

  /* 1. Hero Section */
  .hero-section {
    background: linear-gradient(135deg, var(--secondary-color) 0%, var(--primary-color) 100%);
    color: white;
    padding: 80px 20px;
    text-align: center;
    border-bottom: 5px solid var(--accent-color);
  }
  .hero-title {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 20px;
    color: var(--accent-color);
  }
  .hero-subtitle {
    font-size: 1.5rem;
    margin-bottom: 40px;
    opacity: 0.9;
  }
  .hero-btn {
    background-color: var(--accent-color);
    color: var(--primary-color);
    padding: 15px 40px;
    border-radius: 50px;
    font-weight: bold;
    font-size: 1.2rem;
    text-decoration: none;
    transition: transform 0.3s, background 0.3s;
    display: inline-block;
  }
  .hero-btn:hover {
    transform: scale(1.05);
    background-color: #fff;
  }

  /* 2. Categories */
  .categories-section {
    padding: 60px 20px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .section-title {
    text-align: center;
    font-size: 2.2rem;
    color: var(--secondary-color);
    margin-bottom: 40px;
    position: relative;
  }
  .section-title::after {
    content: '';
    display: block;
    width: 80px;
    height: 4px;
    background-color: var(--accent-color);
    margin: 10px auto 0;
    border-radius: 2px;
  }
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
    gap: 20px;
  }
  .cat-card {
    background: white;
    border-radius: 15px;
    padding: 20px;
    text-align: center;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    transition: transform 0.3s;
    border: 1px solid rgba(212, 175, 55, 0.2);
    text-decoration: none;
  }
  .cat-card:hover {
    transform: translateY(-5px);
    border-color: var(--accent-color);
  }
  .cat-icon {
    font-size: 2.5rem;
    margin-bottom: 10px;
    color: var(--primary-color);
  }
  .cat-name {
    font-weight: 600;
    color: var(--secondary-color);
  }

  /* 3. Promo Strip */
  .promo-strip {
    background-color: var(--accent-color);
    color: var(--primary-color);
    padding: 15px 0;
    text-align: center;
    font-size: 1.2rem;
    font-weight: bold;
  }

  /* 4 & 5. Placeholders (Best Sellers, New Arrivals) */
  .products-placeholder {
    max-width: 1200px;
    margin: 60px auto;
    padding: 0 20px;
  }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 30px;
  }
  .product-card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 10px rgba(0,0,0,0.04);
    border: 1px solid #f0f0f0;
  }
  .product-img {
    background: linear-gradient(45deg, #f5f5f5, #e0e0e0);
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #888;
    font-weight: bold;
  }
  .product-info {
    padding: 20px;
    text-align: center;
  }
  .product-title {
    font-size: 1.1rem;
    margin-bottom: 10px;
    color: var(--secondary-color);
    font-weight: bold;
  }
  .product-price {
    color: var(--primary-color);
    font-weight: bold;
    font-size: 1.2rem;
  }

  /* 6. Story Section */
  .story-section {
    background-color: var(--primary-color);
    color: white;
    padding: 80px 20px;
    margin-top: 40px;
  }
  .story-container {
    max-width: 1000px;
    margin: 0 auto;
    text-align: center;
  }
  .story-container p {
    font-size: 1.2rem;
    opacity: 0.9;
    line-height: 1.8;
  }

  /* 7. Brands */
  .brands-section {
    padding: 60px 20px;
    background-color: white;
  }
  .brands-grid {
    display: flex;
    justify-content: center;
    gap: 30px;
    flex-wrap: wrap;
    max-width: 1200px;
    margin: 0 auto;
  }
  .brand-circle {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background-color: var(--bg-light);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid #eee;
    color: #999;
    font-weight: bold;
  }

  /* 8. Trust Features */
  .trust-section {
    background-color: var(--bg-light);
    padding: 60px 20px;
  }
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
  }
  .trust-item {
    text-align: center;
    padding: 20px;
  }
  .trust-icon {
    font-size: 3rem;
    color: var(--accent-color);
    margin-bottom: 15px;
  }
  .trust-title {
    font-weight: bold;
    color: var(--secondary-color);
  }

  @media (max-width: 768px) {
    .hero-title { font-size: 2rem; }
    .hero-subtitle { font-size: 1.2rem; }
  }
</style>

