{% extends "layouts.master" %}

{% block content %}
<style>
  :root {
    --primary-color: #3b2818; /* Rich Coffee Brown */
    --secondary-color: #1e3b2b; /* Deep Green */
    --accent-color: #cda434; /* Premium Gold */
    --accent-light: #f5eedc; /* Light Gold/Cream */
    --bg-main: #faf8f5; /* Very Light Cream */
    --white: #ffffff;
    --text-dark: #222222;
    --text-light: #666666;
    --border-color: #eaeaea;
    --shadow-soft: 0 10px 30px rgba(0, 0, 0, 0.05);
    --shadow-hover: 0 15px 35px rgba(59, 40, 24, 0.1);
    --radius-md: 12px;
    --radius-lg: 20px;
    --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  }
  
  /* --- Global Header & Footer Fixes --- */
  /* Fix oversized logo in demo header */
  header .navbar-brand,
  .store-header .navbar-brand {
    max-width: 180px !important;
    max-height: 80px !important;
    display: inline-block;
  }
  header .navbar-brand img,
  .store-header .navbar-brand img {
    max-width: 100% !important;
    max-height: 60px !important;
    object-fit: contain !important;
    width: auto !important;
    height: auto !important;
  }
  
  /* Footer spacing cleanup */
  footer.store-footer {
    padding-top: 40px !important;
    padding-bottom: 20px !important;
    background-color: var(--white) !important;
    border-top: 1px solid var(--border-color);
    margin-top: 0 !important;
  }
  footer.store-footer .footer-widget {
    margin-bottom: 30px !important;
  }

  /* --- Homepage Global Styles --- */
  .v2-home-wrapper {
    font-family: 'Tajawal', 'Cairo', sans-serif;
    background-color: var(--bg-main);
    color: var(--text-dark);
    line-height: 1.6;
    overflow-x: hidden;
  }

  .container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .section-padding {
    padding: 80px 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: 50px;
  }
  .section-title {
    font-size: 2.2rem;
    color: var(--secondary-color);
    font-weight: 800;
    margin-bottom: 15px;
    position: relative;
    display: inline-block;
  }
  .section-title::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 3px;
    background-color: var(--accent-color);
    border-radius: 3px;
  }
  .section-subtitle {
    color: var(--text-light);
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto;
  }

  /* --- 1. Promo Strip --- */
  .promo-strip {
    background-color: var(--accent-color);
    color: var(--primary-color);
    text-align: center;
    padding: 12px 20px;
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: 0.5px;
  }

  /* --- 2. Hero Section --- */
  .hero-section {
    position: relative;
    background: linear-gradient(145deg, var(--secondary-color) 0%, #112218 100%);
    color: var(--white);
    padding: 120px 20px;
    text-align: center;
    overflow: hidden;
  }
  /* Decorative CSS Shapes */
  .hero-decoration {
    position: absolute;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(205,164,52,0.1) 0%, rgba(205,164,52,0) 70%);
    border-radius: 50%;
    z-index: 1;
  }
  .hero-dec-1 { top: -100px; right: -100px; width: 400px; height: 400px; }
  .hero-dec-2 { bottom: -50px; left: -50px; }
  
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    margin: 0 auto;
  }
  .hero-title {
    font-size: 3.5rem;
    font-weight: 900;
    color: var(--accent-color);
    margin-bottom: 25px;
    line-height: 1.2;
    text-shadow: 0 4px 15px rgba(0,0,0,0.3);
  }
  .hero-subtitle {
    font-size: 1.3rem;
    margin-bottom: 40px;
    color: #e0e0e0;
    line-height: 1.8;
  }
  .hero-actions {
    display: flex;
    gap: 20px;
    justify-content: center;
  }
  .btn-primary, .btn-outline {
    padding: 16px 45px;
    border-radius: 50px;
    font-weight: 700;
    font-size: 1.1rem;
    text-decoration: none;
    transition: var(--transition);
  }
  .btn-primary {
    background-color: var(--accent-color);
    color: var(--primary-color);
    box-shadow: 0 8px 25px rgba(205, 164, 52, 0.3);
  }
  .btn-primary:hover {
    background-color: var(--white);
    transform: translateY(-3px);
  }
  .btn-outline {
    background-color: transparent;
    color: var(--white);
    border: 2px solid var(--accent-color);
  }
  .btn-outline:hover {
    background-color: var(--accent-color);
    color: var(--primary-color);
    transform: translateY(-3px);
  }

  /* --- 3. Categories --- */
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 25px;
  }
  .cat-card {
    background: var(--white);
    border-radius: var(--radius-md);
    padding: 30px 15px;
    text-align: center;
    box-shadow: var(--shadow-soft);
    transition: var(--transition);
    border: 1px solid var(--border-color);
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .cat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background-color: var(--accent-color);
    transform: scaleX(0);
    transition: var(--transition);
  }
  .cat-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-hover);
    border-color: transparent;
  }
  .cat-card:hover::before {
    transform: scaleX(1);
  }
  .cat-icon {
    font-size: 3rem;
    margin-bottom: 15px;
    color: var(--primary-color);
    transition: var(--transition);
  }
  .cat-card:hover .cat-icon {
    transform: scale(1.1);
    color: var(--accent-color);
  }
  .cat-name {
    font-weight: 700;
    color: var(--secondary-color);
    font-size: 1.1rem;
  }

  /* --- 4. Product Cards (Best Sellers / New Arrivals) --- */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 35px;
  }
  .product-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-soft);
    transition: var(--transition);
    border: 1px solid var(--border-color);
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .product-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-hover);
  }
  .product-badge {
    position: absolute;
    top: 15px;
    right: 15px;
    background-color: var(--accent-color);
    color: var(--primary-color);
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 700;
    z-index: 2;
  }
  .product-img-block {
    height: 240px;
    background: linear-gradient(135deg, var(--bg-main) 0%, #f0ebd8 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .product-icon-art {
    font-size: 5rem;
    opacity: 0.8;
    filter: drop-shadow(0 10px 10px rgba(0,0,0,0.1));
    transition: var(--transition);
  }
  .product-card:hover .product-icon-art {
    transform: scale(1.1) rotate(5deg);
  }
  .product-info {
    padding: 25px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }
  .product-title {
    font-size: 1.25rem;
    margin-bottom: 10px;
    color: var(--secondary-color);
    font-weight: 800;
    line-height: 1.4;
  }
  .product-desc {
    color: var(--text-light);
    font-size: 0.95rem;
    margin-bottom: 20px;
    flex-grow: 1;
  }
  .product-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--border-color);
    padding-top: 15px;
    margin-top: auto;
  }
  .product-price {
    color: var(--primary-color);
    font-weight: 900;
    font-size: 1.4rem;
  }
  .product-add-btn {
    background-color: var(--bg-main);
    color: var(--primary-color);
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    cursor: pointer;
    transition: var(--transition);
  }
  .product-card:hover .product-add-btn {
    background-color: var(--primary-color);
    color: var(--accent-color);
  }

  /* --- 5. Promo Banner --- */
  .wide-promo-banner {
    background: linear-gradient(to right, var(--primary-color), #2a1b10);
    border-radius: var(--radius-lg);
    padding: 60px 40px;
    margin: 40px auto;
    text-align: center;
    color: var(--white);
    position: relative;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(59, 40, 24, 0.2);
  }
  .wide-promo-banner::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(45deg, transparent, transparent 20px, rgba(205,164,52,0.03) 20px, rgba(205,164,52,0.03) 40px);
  }
  .promo-banner-content {
    position: relative;
    z-index: 2;
  }
  .promo-banner-title {
    font-size: 2.8rem;
    color: var(--accent-color);
    font-weight: 900;
    margin-bottom: 15px;
  }
  .promo-banner-text {
    font-size: 1.2rem;
    opacity: 0.9;
  }

  /* --- 6. Story Section (Two Column) --- */
  .story-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
    align-items: center;
    background-color: var(--white);
    border-radius: var(--radius-lg);
    padding: 60px;
    box-shadow: var(--shadow-soft);
  }
  .story-content h2 {
    font-size: 2.5rem;
    color: var(--secondary-color);
    font-weight: 900;
    margin-bottom: 25px;
  }
  .story-content p {
    font-size: 1.15rem;
    color: var(--text-light);
    line-height: 1.8;
    margin-bottom: 20px;
  }
  .story-visual {
    background: linear-gradient(135deg, var(--secondary-color), var(--primary-color));
    height: 100%;
    min-height: 400px;
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: var(--accent-color);
    position: relative;
    overflow: hidden;
  }
  .story-visual-icon {
    font-size: 6rem;
    margin-bottom: 20px;
    position: relative;
    z-index: 2;
  }
  .story-visual-text {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--white);
    position: relative;
    z-index: 2;
  }
  .story-visual::after {
    content: '';
    position: absolute;
    border: 2px solid rgba(205, 164, 52, 0.2);
    width: calc(100% - 40px);
    height: calc(100% - 40px);
    border-radius: var(--radius-md);
  }

  /* --- 7. Brands Section --- */
  .brands-grid {
    display: flex;
    justify-content: center;
    gap: 40px;
    flex-wrap: wrap;
  }
  .brand-item {
    background-color: var(--white);
    padding: 20px 40px;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-soft);
    font-weight: 800;
    font-size: 1.2rem;
    color: var(--text-light);
    border: 1px solid var(--border-color);
    transition: var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 180px;
  }
  .brand-item:hover {
    color: var(--primary-color);
    border-color: var(--accent-color);
    transform: translateY(-5px);
  }

  /* --- 8. Trust Features --- */
  .features-container {
    background-color: var(--white);
    border-radius: var(--radius-lg);
    padding: 60px 40px;
    box-shadow: var(--shadow-soft);
  }
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 40px;
  }
  .trust-item {
    text-align: center;
  }
  .trust-icon-wrap {
    width: 80px;
    height: 80px;
    background-color: var(--accent-light);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    font-size: 2.2rem;
    color: var(--primary-color);
    transition: var(--transition);
  }
  .trust-item:hover .trust-icon-wrap {
    background-color: var(--accent-color);
    color: var(--white);
    transform: rotate(10deg);
  }
  .trust-title {
    font-weight: 800;
    color: var(--secondary-color);
    font-size: 1.2rem;
    margin-bottom: 10px;
  }
  .trust-desc {
    color: var(--text-light);
    font-size: 0.95rem;
  }

  /* --- Responsive Design --- */
  @media (max-width: 992px) {
    .story-wrapper { grid-template-columns: 1fr; }
    .story-visual { min-height: 300px; }
    .hero-title { font-size: 2.8rem; }
  }
  @media (max-width: 768px) {
    .hero-section { padding: 80px 20px; }
    .hero-title { font-size: 2.2rem; }
    .hero-actions { flex-direction: column; }
    .wide-promo-banner { padding: 40px 20px; }
    .promo-banner-title { font-size: 2rem; }
  }
</style>

