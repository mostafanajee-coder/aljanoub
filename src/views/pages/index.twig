        <div class="hero-actions">
          <a href="/products" class="btn-primary">تسوق المجموعات الفاخرة</a>
          <a href="/categories" class="btn-outline">اكتشف العروض</a>
        </div>
      </div>
      
      <div class="hero-visual">
        <div class="hero-visual-inner">
          <!-- Main Hero Art -->
          <div class="shape-coffee" style="animation-delay: 0s;">☕</div>
          <!-- Floating Mini Cards -->
          <div class="shape-badge shape-badge-1">
            <span>🌴</span> تمور ملكية
          </div>
          <div class="shape-badge shape-badge-2">
            <span>🌿</span> هيل اكسترا
