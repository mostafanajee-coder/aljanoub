        </div>
      </div>

    </div>
  </section>

  <!-- 3. Responsive Category Grid -->
  <section class="section-padding container">
    <div class="section-header">
      <h2 class="section-title">أقسام التسوق</h2>
      <p class="section-subtitle">تصفح مجموعاتنا المميزة المختارة لتلبي جميع احتياجات ضيافتك</p>
    </div>
    <div class="cat-grid">
      <a href="/category/coffee" class="cat-card">
        <div class="cat-icon-wrap">☕</div>
        <div class="cat-name">القهوة الفاخرة</div>
      </a>
      <a href="/category/dates" class="cat-card">
        <div class="cat-icon-wrap">🌴</div>
        <div class="cat-name">التمور المنتقاة</div>
      </a>
      <a href="/category/cardamom" class="cat-card">
        <div class="cat-icon-wrap">🌿</div>
        <div class="cat-name">الهيل والزعفران</div>
      </a>
